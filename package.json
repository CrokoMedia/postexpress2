{
  "name": "croko-lab",
  "version": "1.0.0",
  "description": "Croko Lab - Laboratório de conteúdo científico da Agência Croko",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3001",
    "build": "npm run build:remotion && next build",
    "build:remotion": "node scripts/build-remotion-bundle.js",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "check-env": "node scripts/check-env.js",
    "worker": "tsx worker/analysis-worker.ts",
    "worker:dev": "tsx watch worker/analysis-worker.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:unit": "jest --testPathIgnorePatterns=integration",
    "test:supabase": "node scripts/test-supabase-connection.js",
    "test:linking": "node scripts/test-content-linking.js",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:report": "playwright show-report",
    "ocr-gemini": "node scripts/ocr-gemini-analyzer.js",
    "ocr-tesseract": "node scripts/ocr-image-analyzer.js",
    "fix-profile-pics": "node scripts/fix-missing-profile-pics.js",
    "test-profile-pics": "node scripts/test-profile-pic.js",
    "upload-to-cloudinary": "node scripts/upload-profile-pics-to-cloudinary.js"
  },
  "keywords": [
    "instagram",
    "ocr",
    "gemini",
    "content-analysis"
  ],
  "author": "",
  "license": "ISC",
