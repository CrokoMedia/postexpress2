# Supabase
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Apify (scraping Instagram)
APIFY_API_TOKEN=

# IA
ANTHROPIC_API_KEY=
GOOGLE_AI_API_KEY=
OPENAI_API_KEY=
ELEVENLABS_API_KEY=
NANO_BANANA_API_KEY=

# Twitter API (Stream Monitoring)
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_BEARER_TOKEN=

# Cloudinary (imagens)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Google Drive (export de slides) — opcional
GOOGLE_DRIVE_CLIENT_EMAIL=
GOOGLE_DRIVE_PRIVATE_KEY=
GOOGLE_DRIVE_FOLDER_ID=

# Pexels (stock video B-Roll) — opcional
PEXELS_API_KEY=

# Instagram Graph API (publicação automática) — opcional
# Criar Facebook App em: https://developers.facebook.com/apps/
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
INSTAGRAM_REDIRECT_URI=http://localhost:3000/api/auth/instagram/callback
# Produção: https://seudominio.com/api/auth/instagram/callback

# Cron Secret (agendamento de geração de conteúdo)
# Secret para autenticar chamadas do Vercel Cron
# IMPORTANTE: trocar em produção por valor aleatório forte
CRON_SECRET=dev-secret-change-in-production
NEXT_PUBLIC_CRON_SECRET=dev-secret-change-in-production

# Porta do servidor Next.js
PORT=3001
