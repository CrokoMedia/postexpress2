# ============================================
# Supabase Environment Variables Template
# ============================================
# 1. Copie este arquivo para .env:
#    cp .env.supabase.template .env
#
# 2. Preencha os valores abaixo com suas credenciais
#
# 3. Configure as MESMAS variáveis no Railway Dashboard
# ============================================

# --------------------------------------------
# Supabase Credentials
# --------------------------------------------
# Como obter: https://supabase.com/dashboard → Seu Projeto → Settings → API

# Project URL (exemplo: https://abcdefgh.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_URL=https://xxxxx.supabase.co

# Anon/Public Key (exemplo: eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1Ni...
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1Ni...

# Service Role Key (SECRETO - clique "Reveal" no Supabase para ver)
# ⚠️ NUNCA commitar esta chave no Git!
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1Ni...

# --------------------------------------------
# Other Services (Opcional)
# --------------------------------------------

# Anthropic (para geração de conteúdo com Claude)
ANTHROPIC_API_KEY=sk-ant-...

# Google AI (para OCR com Gemini)
GOOGLE_AI_API_KEY=AIza...

# Apify (para scraping do Instagram)
APIFY_API_TOKEN=apify_api_...

# Cloudinary (para upload de imagens)
CLOUDINARY_CLOUD_NAME=seu-cloud-name
CLOUDINARY_API_KEY=123456789012345
CLOUDINARY_API_SECRET=abc123...

# UAZapi (para integração WhatsApp)
UAZAPI_INSTANCE_ID=instance_...
UAZAPI_TOKEN=token_...
UAZAPI_WEBHOOK_URL=https://seu-app.railway.app/api/whatsapp/webhook

# Google Drive (para export de slides)
GOOGLE_DRIVE_CLIENT_EMAIL=seu-service-account@....iam.gserviceaccount.com
GOOGLE_DRIVE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
GOOGLE_DRIVE_FOLDER_ID=1abc...

# --------------------------------------------
# System
# --------------------------------------------
NODE_ENV=development
